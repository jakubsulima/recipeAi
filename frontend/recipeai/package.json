{
  "name": "recipeai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "dev:chrome": "open -a 'Google Chrome' http://localhost:5173 && vite",
    "dev:docker": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "duplicates": "jscpd --config ../../.jscpd.json --output ../../reports/jscpd src tests e2e ../../backendApi/src/main/java --noTips",
    "preview": "vite preview",
    "promo:capture": "PROMO_CAPTURE=1 playwright test e2e/promo-capture.spec.ts",
    "promo:capture:clips": "PROMO_CAPTURE_VIDEO=1 playwright test e2e/promo-video-capture.spec.ts",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "unused": "knip"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@tailwindcss/vite": "^4.0.13",
    "@vitest/ui": "^4.1.8",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "axios": "^1.16.0",
    "posthog-js": "1.365.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.2",
    "react-router-dom": "^7.3.0",
    "vitest": "^4.1.8",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jscpd": "^4.2.2",
    "jsdom": "^26.0.0",
    "knip": "^5.88.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  }
}
