# ==============================
# Core app settings (Dokploy-ready)
# ==============================
BACKEND_IMAGE=ghcr.io/your-github-namespace/recipeai-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-namespace/recipeai-frontend:latest

POSTGRES_DB=recipeai
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

GEMINI_API_KEY=change_me
GEMINI_API_MODEL=gemini-2.5-flash-lite
GEMINI_API_FALLBACK_MODEL=gemini-2.5-flash
GOOGLE_OAUTH_CLIENT_ID=
POSTHOG_ENABLED=false
POSTHOG_KEY=
POSTHOG_API_HOST=
POSTHOG_UI_HOST=https://eu.posthog.com
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
APP_DOMAIN=dishgenie.app
TRAEFIK_BACKEND_PATH_PREFIX=/api
TRAEFIK_BACKEND_ROUTER_PRIORITY=100
TRAEFIK_FRONTEND_ROUTER_PRIORITY=50
BACKEND_INTERNAL_PORT=8080
FRONTEND_INTERNAL_PORT=8080

ALLOWED_ORIGINS=https://dishgenie.app,https://www.dishgenie.app
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET_KEY=change_me_at_least_32_characters_long
TRUSTED_PROXY_IPS=
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=Lax

FREE_PLAN_RECIPE_LIMIT=75
PAID_PLAN_RECIPE_LIMIT=-1

# Frontend runtime port inside container
FRONTEND_PORT=80

# Frontend config:
# - VITE_API_URL is build-time (GitHub Actions Variables)
# - GOOGLE_OAUTH_CLIENT_ID is runtime (compose/Dokploy) and controls Google login on the frontend
# - POSTHOG_* values are runtime and control consent-gated analytics
