# ==============================
# Core app settings (Dokploy-ready)
# ==============================
POSTGRES_DB=recipeai
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

GEMINI_API_KEY=change_me
GOOGLE_OAUTH_CLIENT_ID=

ALLOWED_ORIGINS=https://example.com,https://www.example.com
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET_KEY=change_me_at_least_32_characters_long
TRUSTED_PROXY_IPS=
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=Lax

FREE_PLAN_RECIPE_LIMIT=75
PAID_PLAN_RECIPE_LIMIT=-1

# Frontend build/runtime routing
# Option A (recommended with single Dokploy public endpoint):
#   VITE_API_URL=/api/
# Option B (separate public API domain in Dokploy):
#   VITE_API_URL=https://api.example.com/
VITE_API_URL=/api/
FRONTEND_PORT=80
